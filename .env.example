# Copy to .env and adjust. docker-compose loads this via `env_file: .env`.

# --- HTTP / API ---
BACNET_LAB_HTTP_HOST=0.0.0.0
BACNET_LAB_HTTP_PORT=8080

# --- BACnet/IP ---
BACNET_LAB_BACNET_IP=0.0.0.0
BACNET_LAB_BACNET_PORT_START=47808

# --- Persistence (SQLite metadata/events) ---
BACNET_LAB_DB_PATH=bacnet_lab.db
BACNET_LAB_LOG_LEVEL=INFO

# --- Auth (leave empty to disable; NOT recommended in production) ---
BACNET_LAB_AUTH_USERNAME=admin
BACNET_LAB_AUTH_PASSWORD=change-me-please

# --- Real-time simulation engine ---
BACNET_LAB_SIM_ENABLED=true
BACNET_LAB_SIM_AUTOSTART=true
BACNET_LAB_SIM_TICK_HZ=1
BACNET_LAB_SIM_SPEED=60.0          # sim-time acceleration (60 = 24h in 24min; 1 = real-time)
BACNET_LAB_SIM_SEED=               # set an int for reproducible runs
BACNET_LAB_SIM_NOISE_LEVEL=1.0
BACNET_LAB_SIM_CONFIG=config/simulation.yaml
# world model (coupled physics)
BACNET_LAB_SIM_WORLD_ENABLED=true
BACNET_LAB_SIM_WEATHER=temperate   # temperate | hot | cold
BACNET_LAB_SIM_OCCUPANCY=office    # office | 24x7 | none
# fault injection
BACNET_LAB_SIM_FAULTS_ENABLED=false
BACNET_LAB_SIM_FAULT_RATE=0.0
# generative scale (0 = use YAML templates as-is)
BACNET_LAB_SIM_DEVICE_COUNT=0

# --- Time-series DB (TimescaleDB, dual-write historian) ---
BACNET_LAB_TSDB_ENABLED=true
BACNET_LAB_TSDB_DSN=postgres://bacnet:bacnet@localhost:5544/bacnet
BACNET_LAB_TSDB_SAMPLE_INTERVAL_S=5
BACNET_LAB_TSDB_BATCH_SIZE=500

# --- LLM reasoning copilot (Open-WebUI / Ollama, OpenAI-compatible) ---
BACNET_LAB_LLM_ENABLED=false
BACNET_LAB_LLM_BASE_URL=https://ollamallm.tools.thefusionapps.com
BACNET_LAB_LLM_API_KEY=                 # Bearer key from Open-WebUI (secret — keep out of git)
BACNET_LAB_LLM_MODEL=llama3.1:8b
BACNET_LAB_LLM_TIMEOUT_S=60
